# ─── DigiStrive Billing — Backend Environment Variables ──────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to Git.

# ─── Database ─────────────────────────────────────────────────────────────────
# Your MongoDB Atlas connection string (includes username + password)
MONGO_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@cluster0.xxxxx.mongodb.net/digibilling?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────────────────────
# CRITICAL: Use a long random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# This signs ALL login tokens. If exposed, anyone can impersonate any user.
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Your actual frontend domain. Only this origin can call the API.
# Multiple domains (comma-separated): https://app.domain.com,https://domain.com
FRONTEND_URL=https://app.digistrivebilling.com

# ─── Signup Protection ────────────────────────────────────────────────────────
# This key must be sent as the x-signup-key header when creating a new tenant.
# Only YOU (or your onboarding flow) should know this.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SIGNUP_SECRET_KEY=REPLACE_WITH_32_CHAR_RANDOM_HEX_STRING
